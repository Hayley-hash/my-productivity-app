    </button>

    <button onclick="show('stats')" style="padding:12px; border:1px solid #333; background:black; color:white;">
      Stats →
    </button>

    <button onclick="show('dashboard')" style="padding:12px; border:1px solid #333; background:black; color:white;">
      Dashboard →
    </button>

    <button onclick="show('schedule')" style="padding:12px; border:1px solid #333; background:black; color:white;">
      Schedule →
    </button>

  </div>

  <!-- LOWER TEXT SECTIONS -->
  <div style="margin-top:60px; opacity:0.6;">
