<div id="home" class="page active">

  <div class="app">

    <!-- TOP BAR -->
    <div class="topbar">
      <h2>Life OS</h2>
      <p>Your daily system for habits and focus</p>
    </div>

    <!-- HERO GRID -->
    <div class="grid">

      <div class="card main">
        <p>Welcome back 👋</p>
        <button onclick="show('dashboard')">Enter App</button>
      </div>

      <div class="card small" onclick="show('journal')">
        Journal
      </div>

      <div class="card small" onclick="show('stats')">
        Stats
      </div>

      <div class="card small" onclick="show('schedule')">
        Schedule
      </div>

    </div>

    <!-- IMAGE SECTION -->
    <div class="banner">
      <img src="home.png" />
      <p>Coming soon: AI-powered insights</p>
    </div>

  </div>

</div>
